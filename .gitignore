# Dell 3521 Hackintosh - .gitignore

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Thumbnails
._*

# Files that might appear on external media
._*

# Source control
.Spotlight-V100
.Trashes

# EFI outputs (should be built by user)
Output/
Results/

# Hardware reports (contain real serial numbers)
SysReport/
*.json
!config_examples/*.json

# Temporary files
*.tmp
*.log
*.swp
*~

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# IDE
.vscode/
.idea/
*.sublime-*

# OpenCore builds
OpenCore-*. RELEASE/
Build/

# Kexts (should be downloaded by user)
*.kext

# EFI template should be populated by user
EFI/OC/Kexts/*
!EFI/OC/Kexts/.gitkeep
EFI/OC/ACPI/*
!EFI/OC/ACPI/.gitkeep
EFI/OC/Drivers/*
!EFI/OC/Drivers/.gitkeep
EFI/OC/Tools/*
!EFI/OC/Tools/.gitkeep
EFI/OC/Resources/*
!EFI/OC/Resources/.gitkeep

# Keep sample configs
!config_examples/